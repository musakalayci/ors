
tür argümanlar 
{
  sayı              tam; 
  _girdi          **harf; 
  _işletimSistemi **harf;
}


öz *argümanlar 
iş Yapılandır 
  sayı   tam,
  _girdi **t8,
  _işletimSistemi **t8
{
  öz->sayı = sayı;
  öz->_girdi = _girdi;
  öz->_işletimSistemi = _işletimSistemi;
}

öz *argümanlar 
iş GirdiYazdır
{
  
  her t := öz->_girdi; *t; t++:
    c::stdio::printf(
        "=> %s\n", *t);
}