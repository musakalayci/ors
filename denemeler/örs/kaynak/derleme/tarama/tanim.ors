Tarama *t 
iş SıradakiSözcük : *simge::t 
{
  j := 0_st32;
  i := 0_st32;
  başlangıç := Tarama->imleç.konum;
  diziSonu  := Tarama->imleç.okumaKonumu;
  VekilMetin := &Tarama->Belge->Dizi[başlangıç];
  her ; j < 256; j++:
  {
    durum Tarama->imleç.okunan:
    {
      seçim altyapı::utf8::belirteçler:
        diziSonu++;
        utfh := *<*t16>&VekilMetin[i];
        i++;
        durum utfh:
        {
          seçim altyapı::utf8::tümü:
            Tarama->_bellek[j] = Tarama->imleç.okunan;
            j++;
            Tarama->_bellek[j] = VekilMetin[j];
          varsayılan: 
            dön Tarama->Simgeler->YeniEkle(
            simge::türleri::Hata, 
            simge::türleri::Hata);
        }
        Tarama->imleç.sütun--;
        Tarama->ilerlet();
      seçim 
        altyapı::ascii::küçükler, 
        altyapı::ascii::büyükler,
        altyapı::ascii::Alt_Tire:
        Tarama->_bellek[j] = Tarama->imleç.okunan;
      varsayılan: 
        son;
    }
    i++; 
    diziSonu++;
    Tarama->ilerlet();
  }
  Tarama->_bellek[j] = 0_st8;
  Simge := Tarama->Simgeler->YeniEkle(
            simge::türleri::Metin, 
            simge::türleri::Metin);
  Metin := temiz(metin);
    /*->Yapılandır(|mimari|j)
    ->Harflerden(Tarama->_bellek, |mimari|j);*/ 
  Simge->içerik.Metin = Metin;
  stdio::printf("-> %s, %d, %s\n", Tarama->_bellek, j, Metin->Harfler);
  Simge->konum.baş   = başlangıç;
  Simge->konum.bitiş = diziSonu - 1;
  dön Simge;
}

öz *t 
iş Tara : *simge::t 
{
  değer Simge *simge::t = {};
  durum öz->Simgeler->Son->özellik.türü:
  {
    seçim simge::türleri::Son:
      stdio::printf("--son--\n");
      dön öz->Simgeler->Son;
    varsayılan:
      durum öz->imleç.okunan:
      {
        seçim simge::türleri::Son: 
         Simge = öz->Simgeler->YeniEkle(
            simge::türleri::Son, 
            simge::türleri::Son);
          dön Simge;
        seçim 
          altyapı::ascii::Yeni_Satır: 
          öz->imleç.sütun = 0;
          öz->imleç.satır++;
          geç;
        seçim 
          altyapı::ascii::Boşluk, 
          altyapı::ascii::Satır:
            öz->ilerlet();
            tekrar;
        seçim 
          altyapı::ascii::küçükler, 
          altyapı::ascii::büyükler,
          altyapı::ascii::utf_belirteci, 
          altyapı::ascii::Alt_Tire:
           dön öz->SıradakiSözcük();
        seçim altyapı::ascii::noktalama:
          değer noktalama t32 = <t32>öz->imleç.okunan;
          başlangıç := öz->imleç.konum;
          sonu      := öz->imleç.okumaKonumu;
          öz->ilerlet();
          durum noktalama:
          {
            seçim altyapı::ascii::İki_Nokta:
              durum öz->imleç.okunan:
              {
                seçim altyapı::ascii::İki_Nokta:
                  sonu++;
                  öz->ilerlet();
                  noktalama = simge::özellik::Arama;
                seçim altyapı::ascii::Eşit:
                  sonu++;
                  öz->ilerlet();
                  noktalama = simge::özellik::Pascal_Eşit;
              }
            seçim altyapı::ascii::Ve:
              durum öz->imleç.okunan:
              {
                seçim altyapı::ascii::Ve:
                  sonu++;
                  öz->ilerlet();
                  noktalama = simge::özellik::Ve;
                seçim altyapı::ascii::Eşit:
                  sonu++;
                  öz->ilerlet();
                  noktalama = simge::özellik::Tekil_Ve_Eşit;
              }
            seçim altyapı::ascii::Küçük:
              durum öz->imleç.okunan:
              {
                seçim altyapı::ascii::Eksi:
                  sonu++;
                  öz->ilerlet();
                  noktalama = simge::özellik::Geri_Ok;
                seçim altyapı::ascii::Küçük:
                  sonu++;
                  öz->ilerlet();
                  noktalama = simge::özellik::Sola_Kaydır;
                seçim altyapı::ascii::Eşit:
                  sonu++;
                  öz->ilerlet();
                  noktalama = simge::özellik::Küçük_Eşit;
              }
            seçim altyapı::ascii::Büyük:
              durum öz->imleç.okunan:
              {
                seçim altyapı::ascii::Büyük:
                  sonu++;
                  öz->ilerlet();
                  noktalama = simge::özellik::Sağa_Kaydır;
                seçim altyapı::ascii::Eşit:
                  sonu++;
                  öz->ilerlet();
                  noktalama = simge::özellik::Büyük_Eşit;
              }
            seçim altyapı::ascii::Şapka:
              durum öz->imleç.okunan:
              {
                seçim altyapı::ascii::Eşit:
                  sonu++;
                  öz->ilerlet();
                  noktalama = simge::özellik::Tekil_Ters_Ya_da_Eşit;
              }
            seçim altyapı::ascii::Bölü:
              durum öz->imleç.okunan:
              {
                seçim altyapı::ascii::Eşit:
                  sonu++;
                  öz->ilerlet();
                  noktalama = simge::özellik::Böl_Eşit;
              }
            seçim altyapı::ascii::Ünlem:
              durum öz->imleç.okunan:
              {
                seçim altyapı::ascii::Eşit:
                  sonu++;
                  öz->ilerlet();
                  noktalama = simge::özellik::Eşit_Değildir;
              }
            seçim altyapı::ascii::Eşit:
              durum öz->imleç.okunan:
              {
                seçim altyapı::ascii::Eşit:
                  sonu++;
                  öz->ilerlet();
                  noktalama = simge::özellik::Eşittir;
                seçim altyapı::ascii::Büyük:
                  sonu++;
                  öz->ilerlet();
                  noktalama = simge::özellik::İleri_Çift_Ok;
              }
            seçim altyapı::ascii::Artı:
              durum öz->imleç.okunan:
              {
                seçim altyapı::ascii::Artı:
                  sonu++;
                  öz->ilerlet();
                  noktalama = simge::özellik::Arttır;
                seçim altyapı::ascii::Eşit:
                  sonu++;
                  öz->ilerlet();
                  noktalama = simge::özellik::Artı_Eşit;
              }
            seçim altyapı::ascii::Eksi:
              durum öz->imleç.okunan:
              {
                seçim altyapı::ascii::Büyük: 
                  sonu++;
                  öz->ilerlet();
                  noktalama = simge::özellik::İleri_Ok;
                seçim altyapı::ascii::Eksi:
                  sonu++;
                  öz->ilerlet();
                  noktalama = simge::özellik::Azalt;
                seçim altyapı::ascii::Eşit:
                  sonu++;
                  öz->ilerlet();
                  noktalama = simge::özellik::Eksi_Eşit;
              }
            seçim altyapı::ascii::Ayraç:
              durum öz->imleç.okunan:
              {
                seçim altyapı::ascii::Ayraç:
                  sonu++;
                  öz->ilerlet();
                  noktalama = simge::özellik::Ya_Da;
                seçim altyapı::ascii::Eşit:
                  sonu++;
                  öz->ilerlet();
                  noktalama = simge::özellik::Tekil_Ya_Da_Eşit; 
              }
          }
          Simge = öz->Simgeler->YeniEkle(
            simge::türleri::Noktalama, 
            noktalama);
          dön Simge;

        varsayılan: 
          Simge = öz->Simgeler->YeniEkle(
            simge::türleri::Hata, 
            simge::hata::Bilinmeyen);
      }
    
  }

  öz->ilerlet();
  dön Simge;
}

öz *t 
iş Deney 
{
  d := 10;
  Simge := öz->Simgeler->Baş;
  tüm Simge->özellik.türü:
  {
   Simge = öz->Tara();
   durum Simge->özellik.türü:
   {
     seçim simge::türleri::Hata:
      Simge->Yazdır();
      son;
   }
   Simge->Yazdır();
   unistd::usleep(20000);
  }
  //öz->Döküm();
}

iş Arayüz Simge *simge::t
{
  Simge->Yazdır();
}

Tarama *t 
iş Tak Belge *belge::bayt 
{
  Tarama->Belge = Belge;
  //sıkıntı var bu işlemin bu haznede görülmesi lazım
  Tarama->imleç.Sıfırla();
  Simge := simge::Yeni(Tarama, simge::türleri::Baş, simge::türleri::Baş);
  Tarama->Simgeler->Ekle(Simge);
  Tarama->ilerlet();
}

Tarama *t 
iş Sök 
{
}



Tarama *t 
iş Döküm
{
  stdio::printf("---------------------\n");

  her Simge := Tarama->Simgeler->Baş; Simge; Simge = Simge->Sonraki:
    Simge->Yazdır();
  stdio::printf("  --belge--\n");

  Tarama->Belge->Yazdır();
  stdio::printf("  --belge--\n");
    stdio::printf("---------------------\n");

}

Tarama *t 
iş ilerlet
{
  eğer Tarama->imleç.okumaKonumu < <t32>Tarama->Belge->boyut: 
  {
    Tarama->imleç.okunan = Tarama->Belge->Dizi[Tarama->imleç.okumaKonumu]; 
  }
  değilse 
    Tarama->imleç.okunan = 0_st8;
  Tarama->imleç.konum = Tarama->imleç.okumaKonumu;
  Tarama->imleç.okumaKonumu++;
  Tarama->imleç.sütun++;
}

Tarama *t 
iş Temizle 
{
  Tarama->Simgeler->Temizle();
  sil Tarama->Simgeler;
}